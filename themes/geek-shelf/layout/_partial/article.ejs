<article class="post">
  <header class="post-header">
    <h1 class="post-title"><%= post.title %></h1>
    <div class="post-meta">
      <time class="post-date" datetime="<%= date(post.date, 'YYYY-MM-DDTHH:mm:ss') %>">
        <%= date(post.date, 'YYYY-MM-DD') %>
      </time>
      <% if (post.categories && post.categories.length) { %>
        <span class="meta-sep">/</span>
        <%- partial('post-terms', { post: post, type: 'category' }) %>
      <% } %>
      <% if (post.tags && post.tags.length) { %>
        <span class="meta-sep">/</span>
        <%- partial('post-terms', { post: post, type: 'tag' }) %>
      <% } %>
    </div>
  </header>
  <div class="post-body">
    <%- post.content %>
  </div>
</article>
