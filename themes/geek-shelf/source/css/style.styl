// ============================================================
// geek-shelf theme · 极客黑白风
// 黑白主调 + 灰阶过渡 / 等宽字体 / 无圆角无阴影无渐变
// ============================================================

// ---- 变量 ----
color-text = #1a1a1a
color-bg = #ffffff
color-line = #d0d0d0
color-hover-bg = #f0f0f0
color-hover-text = #1a1a1a
color-active-bg = #e0e0e0
color-active-text = #000
color-bar-bg = #1a1a1a
color-bar-text = #ffffff
color-code-bg = #2a2a2a
color-code-text = #e0e0e0
font-mono = ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas, "Liberation Mono", monospace
width-shelf = 280px
height-topbar = 56px

// ---- mixin ----
hover-soft()
  transition background-color 0.12s ease, color 0.12s ease
  &:hover
    background color-hover-bg
    color color-hover-text

// ---- reset ----
*
  margin 0
  padding 0
  box-sizing border-box

html, body
  height 100%

body
  font-family font-mono
  color color-text
  background color-bg
  font-size 14px
  line-height 1.6
  -webkit-font-smoothing antialiased

a
  color color-text
  text-decoration underline
  hover-soft()

// ---- 顶部色块 ----
.topbar
  height height-topbar
  background color-bar-bg
  color color-bar-text
  display flex
  align-items center
  justify-content space-between
  padding 0 24px
  position sticky
  top 0
  z-index 100

.brand
  display flex
  align-items baseline
  gap 12px

.brand-title
  font-size 16px
  font-weight bold
  letter-spacing 0.04em
  color color-bar-text
  text-decoration none
  // 在黑底顶栏内，hover/focus 仅加下划线，不变背景色（避免与全局 a:hover 浅灰底冲突）
  &:hover, &:focus
    background transparent
    color color-bar-text
    text-decoration underline
  &:focus-visible
    outline none
    text-decoration underline

.brand-sub
  font-size 12px
  opacity 0.7

.topnav
  display flex
  gap 20px

.nav-item
  color color-bar-text
  font-size 13px
  text-decoration none
  letter-spacing 0.04em
  padding 4px 8px
  transition background-color 0.12s ease, color 0.12s ease
  &:hover, &:focus
    background color-bar-text
    color color-bar-bg
  &:focus-visible
    outline none

// ---- 主布局：左书架 + 右内容 ----
.main-layout
  display flex
  align-items flex-start
  min-height calc(100vh - 56px)

// ---- 左侧书架 ----
.shelf
  width width-shelf
  flex-shrink 0
  border-right 1px solid color-line
  position sticky
  top height-topbar
  height calc(100vh - 56px)
  overflow-y auto

.shelf-head
  font-size 10px
  font-weight normal
  letter-spacing 0.18em
  text-transform uppercase
  color #999
  padding 20px 20px 12px
  border-bottom 1px solid color-line

.shelf-list
  list-style none

.shelf-item
  border-bottom 1px solid color-line

.shelf-cat
  width 100%
  border none
  text-align left
  padding 14px 20px
  font-family font-mono
  font-size 13px
  font-weight bold
  cursor pointer
  display flex
  justify-content space-between
  align-items center
  color color-text
  hover-soft()
  &.active
    background color-active-bg
    color color-active-text

.cat-name
  flex 1

.cat-count
  font-size 11px
  font-weight normal
  opacity 0.5
  margin-left 8px

.shelf-posts
  list-style none
  display none
  background #fafafa
  border-top 1px solid color-line

.shelf-item .shelf-posts.open
  display block

.shelf-posts li
  border-bottom 1px solid color-line
  &:last-child
    border-bottom none

.post-link
  display block
  padding 10px 20px 10px 32px
  font-size 12px
  text-decoration none
  color color-text
  hover-soft()
  &.current
    background color-active-bg
    color color-active-text
    font-weight bold

.shelf-empty
  padding 20px
  font-size 12px
  opacity 0.5

// ---- 右侧内容区 ----
.content
  flex 1
  padding 40px 48px
  min-width 0

// ---- 首页文章列表 ----
.post-list
  max-width 720px

.post-item
  padding 20px 0
  border-bottom 1px solid color-line
  &:first-child
    padding-top 0

.item-date
  font-size 11px
  letter-spacing 0.08em
  opacity 0.6
  margin-bottom 6px

.item-title
  font-size 18px
  font-weight bold
  a
    text-decoration none
    hover-soft()

.item-excerpt
  margin-top 8px
  font-size 13px
  opacity 0.8

// ---- 文章详情 ----
.post
  max-width 720px

.post-header
  border-bottom 1px solid color-line
  padding-bottom 16px
  margin-bottom 24px

.post-title
  font-size 24px
  font-weight bold
  line-height 1.3
  margin-bottom 12px
  a
    text-decoration none
    hover-soft()

.post-meta
  font-size 12px
  opacity 0.7

.meta-sep
  margin 0 8px

.post-categories, .post-tags
  a
    text-decoration none
    hover-soft()

// ---- 文章正文 ----
.post-body
  font-size 14px
  line-height 1.7
  h1, h2, h3, h4, h5, h6
    font-weight bold
    margin 1.4em 0 0.6em
    line-height 1.3
  h1
    font-size 20px
    border-bottom 2px solid color-line
    padding-bottom 4px
  h2
    font-size 17px
    border-bottom 1px solid color-line
    padding-bottom 4px
  h3
    font-size 15px
  p
    margin 0.8em 0
  ul, ol
    margin 0.8em 0
    padding-left 1.4em
  li
    margin 0.3em 0
  blockquote
    border-left 3px solid color-line
    padding 4px 12px
    margin 1em 0
    & > p
      margin 0.4em 0
  code
    font-family font-mono
    background color-active-bg
    color color-active-text
    padding 1px 5px
    font-size 0.92em
  pre
    background color-code-bg
    color color-code-text
    padding 14px 16px
    overflow-x auto
    margin 1em 0
    font-size 13px
    line-height 1.5
    // 禁用浏览器对可滚动 pre 的默认 :focus 高亮（白底白字 bug 来源）
    &:focus
      outline none
      background color-code-bg
      color color-code-text
    &:focus-visible
      outline none
    code
      background transparent
      color inherit
      padding 0
  // Hexo highlight.js 渲染的代码块：<figure.highlight><table><td.gutter><td.code>
  figure.highlight
    background color-code-bg
    margin 1em 0
    overflow-x auto
    &:focus
      outline none
      background color-code-bg
    &:focus-visible
      outline none
    pre
      background transparent
      margin 0
      padding 0
    .gutter
      display none    // 关行号：直接隐藏左侧行号列
    .code pre
      padding 14px 16px
      color color-code-text
  table
    border-collapse collapse
    margin 1em 0
    width 100%
  th, td
    border 1px solid color-line
    padding 6px 10px
    text-align left
  th
    background color-active-bg
    color color-active-text
    font-weight bold
  tr:hover td
    background color-hover-bg
  // 代码块也用 <table> 渲染，需排除 figure.highlight 内的 td：
  // - 去 border（避免代码块上下出现白线）
  // - 去 hover 背景（避免鼠标移过代码变浅灰底）
  figure.highlight
    td
      border none
      padding 0
    tr:hover td
      background transparent
  img
    max-width 100%
    height auto
    display block
    border 1px solid color-line
  a
    text-decoration underline
    hover-soft()

// ---- 上下篇导航 ----
.post-nav
  display flex
  justify-content space-between
  margin-top 40px
  padding-top 16px
  border-top 1px solid color-line
  max-width 720px

.post-nav-cell
  flex 1
  &.right
    text-align right

.nav-label
  display block
  font-size 10px
  letter-spacing 0.12em
  opacity 0.6
  margin-bottom 4px

.nav-link
  font-size 13px
  text-decoration none
  font-weight bold
  hover-soft()

// ---- 分页 ----
.pager
  display flex
  justify-content space-between
  margin-top 32px
  padding-top 16px
  border-top 1px solid color-line
  max-width 720px

.pager-cell
  font-size 12px
  letter-spacing 0.08em
  text-decoration none
  font-weight bold
  &[aria-disabled="true"]
    opacity 0.3
    pointer-events none

// ---- 归档 ----
.archive
  max-width 720px

.archive-title
  font-size 16px
  font-weight bold
  letter-spacing 0.08em
  padding-bottom 12px
  border-bottom 2px solid color-line
  margin-bottom 20px

.archive-year
  font-size 14px
  font-weight bold
  margin 20px 0 8px
  padding 4px 8px
  background color-bar-bg
  color color-bar-text
  display inline-block

.archive-row
  display flex
  gap 16px
  align-items baseline
  padding 8px 0
  border-bottom 1px solid color-line

.archive-date
  font-size 11px
  opacity 0.6
  flex-shrink 0
  width 60px

.archive-link
  font-size 13px
  text-decoration none
  hover-soft()

// ---- footer ----
.site-footer
  border-top 1px solid color-line
  padding 16px 24px
  font-size 11px

.footer-inner
  display flex
  gap 8px
  align-items center

.footer-sep
  opacity 0.4

// ---- 响应式 ----
@media (max-width: 768px)
  .topbar
    padding 0 16px
  .topnav
    gap 12px
  .main-layout
    flex-direction column
  .shelf
    width 100%
    position static
    height auto
    border-right none
    border-bottom 1px solid color-line
  .content
    padding 24px 16px
